{
  "name": "miniflare",
  "version": "4.20260507.1",
  "description": "Fun, full-featured, fully-local simulator for Cloudflare Workers",
  "keywords": [
    "cloudflare",
    "cloudworker",
    "local",
    "worker",
    "workers"
  ],
  "homepage": "https://github.com/cloudflare/workers-sdk/tree/main/packages/miniflare#readme",
  "bugs": {
    "url": "https://github.com/cloudflare/workers-sdk/issues"
  },
  "license": "MIT",
  "author": "MrBBot <me@mrbbot.dev>",
  "repository": {
    "type": "git",
    "url": "https://github.com/cloudflare/workers-sdk.git",
    "directory": "packages/miniflare"
  },
  "bin": {
    "miniflare": "bootstrap.js"
  },
  "files": [
    "dist/src",
    "dist/local-explorer-ui",
    "bootstrap.js"
  ],
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@cspotcode/source-map-support": "0.8.1",
    "sharp": "^0.34.5",
    "undici": "7.24.8",
    "workerd": "1.20260507.1",
    "ws": "8.18.0",
    "youch": "4.1.0-beta.10"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260507.1",
    "@hey-api/openapi-ts": "^0.94.0",
    "@microsoft/api-extractor": "^7.52.8",
    "@puppeteer/browsers": "^2.10.6",
    "@types/debug": "^4.1.7",
    "@types/estree": "^1.0.0",
    "@types/glob-to-regexp": "^0.4.1",
    "@types/http-cache-semantics": "^4.0.1",
    "@types/mime": "^3.0.4",
    "@types/node": "^22.10.1",
    "@types/stoppable": "^1.1.1",
    "@types/which": "^2.0.1",
    "@types/ws": "^8.5.7",
    "acorn": "8.14.0",
    "acorn-import-phases": "^1.0.4",
    "acorn-walk": "8.3.2",
    "capnp-es": "^0.0.14",
    "capnweb": "^0.5.0",
    "chokidar": "^4.0.1",
    "ci-info": "^4.4.0",
    "concurrently": "^8.2.2",
    "devalue": "^5.6.3",
    "devtools-protocol": "^0.0.1182435",
    "esbuild": "0.27.3",
    "expect-type": "^0.15.0",
    "get-port": "^7.1.0",
    "glob-to-regexp": "0.4.1",
    "hono": "^4.12.5",
    "http-cache-semantics": "^4.1.0",
    "jsonc-parser": "^3.2.0",
    "kleur": "^4.1.5",
    "mime": "^3.0.0",
    "postal-mime": "^2.4.3",
    "pretty-bytes": "^6.0.0",
    "source-map": "^0.6.1",
    "stoppable": "1.1.0",
    "ts-dedent": "^2.2.0",
    "typescript": "~5.8.3",
    "vitest": "4.1.0",
    "which": "^2.0.2",
    "xdg-app-paths": "^8.3.0",
    "zod": "^3.25.76",
    "@cloudflare/cli-shared-helpers": "0.1.2",
    "@cloudflare/containers-shared": "0.14.1",
    "@cloudflare/kv-asset-handler": "0.5.0",
    "@cloudflare/local-explorer-ui": "0.13.3",
    "@cloudflare/workers-shared": "0.19.5",
    "@cloudflare/workers-utils": "0.20.0",
    "@cloudflare/workflows-shared": "0.10.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "volta": {
    "extends": "../../package.json"
  },
  "workers-sdk": {
    "prerelease": true
  },
  "scripts": {
    "build": "node scripts/build.mjs && pnpm run types:build",
    "capnp:workerd": "capnp-es node_modules/workerd/workerd.capnp -ots:src/runtime/config/generated --src-prefix=node_modules/workerd",
    "check:generate-api": "node -r esbuild-register scripts/check-generate-api.ts",
    "check:type": "tsc",
    "clean": "node -r esbuild-register ../../tools/clean/clean.ts ./dist ./dist-types",
    "dev": "concurrently -n esbuild,typechk,typewrk -c yellow,blue,blue.dim \"node scripts/build.mjs --watch\" \"node scripts/types.mjs tsconfig.json --bundle --watch\" \"node scripts/types.mjs src/workers/tsconfig.json --watch\"",
    "generate:api": "pnpm generate:openapi && pnpm generate:types",
    "generate:openapi": "node -r esbuild-register scripts/filter-openapi.ts -i $OPENAPI_INPUT_PATH",
    "generate:types": "openapi-ts && oxfmt src/workers/local-explorer/openapi.local.json src/workers/local-explorer/generated",
    "test": "vitest run",
    "posttest": "node -r esbuild-register ../../tools/clean/clean.ts ./.tmp",
    "test:ci": "pnpm run test",
    "types:build": "node scripts/types.mjs tsconfig.json --bundle && node scripts/types.mjs src/workers/tsconfig.json"
  }
}